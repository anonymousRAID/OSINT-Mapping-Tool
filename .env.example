# Google Maps credentials — OPTIONAL.
# Leave both blank to launch straight into the app's first-run screen, where
# you can pick OpenStreetMap (no key needed) or Google Maps.
# Fill these in only if you want Google Maps mode. Non-empty values here are
# written into public/app.config.json when the container starts, and the
# first-run screen then skips asking for a key.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MAP_ID=
